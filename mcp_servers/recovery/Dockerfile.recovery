FROM python:3.10-slim
WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y socat && rm -rf /var/lib/apt/lists/*
RUN pip install --no-cache-dir mcp fastmcp docker paho-mqtt influxdb-client
COPY mcp_edge_recovery.py .
EXPOSE 8000

CMD ["socat", "TCP-LISTEN:8000,fork,reuseaddr", "EXEC:'python -u mcp_edge_recovery.py'"]
